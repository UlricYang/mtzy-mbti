# ============================================
# MTZY-MBTI 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# --------------------------------------------
# Filepath Resolver 配置
# --------------------------------------------
# 外部API地址 - 用于动态获取测评数据文件路径
# 如果请求中没有提供filepath，会调用此API获取
FILEPATH_API_URL=http://localhost:8080/api/filepath

# 认证Token - 用于访问外部API
# 请填入实际的认证token，不要提交真实的token到git
API_TOKEN=your-secret-token-here

# --------------------------------------------
# 生产环境覆盖配置（可选）
# --------------------------------------------
# PROD_FILEPATH_API_URL=http://prod-api.example.com/filepath
# PROD_API_TOKEN=prod-secret-token-here

# --------------------------------------------
# 开发环境覆盖配置（可选）
# --------------------------------------------
# DEV_FILEPATH_API_URL=http://localhost:9998/mock-api/filepath